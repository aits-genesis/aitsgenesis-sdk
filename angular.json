{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "schematicCollections": ["angular-eslint"],
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "@aits-genesis/core": {
      "projectType": "library",
      "root": "projects/aits-genesis/core",
      "sourceRoot": "projects/aits-genesis/core/src",
      "prefix": "x",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/aits-genesis/core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/aits-genesis/core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/aits-genesis/core/tsconfig.spec.json"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/aits-genesis/core/**/*.ts",
              "projects/aits-genesis/core/**/*.html"
            ]
          }
        }
      }
    },
