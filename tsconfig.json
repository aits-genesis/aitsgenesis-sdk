/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "@aits-genesis/auth": ["./dist/aits-genesis/auth"],
      "@aits-genesis/core": ["./dist/aits-genesis/core"],
      "@aits-genesis/forms": ["./dist/aits-genesis/forms"],
      "@aits-genesis/http": ["./dist/aits-genesis/http"],
      "@aits-genesis/models": ["./dist/aits-genesis/models"],
      "@aits-genesis/org": ["./dist/aits-genesis/org"],
      "@aits-genesis/reporting": ["./dist/aits-genesis/reporting"],
      "@aits-genesis/security": ["./dist/aits-genesis/security"],
      "@aits-genesis/ui": ["./dist/aits-genesis/ui"],
      "@aits-genesis/utils": ["./dist/aits-genesis/utils"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/libs/core/tsconfig.lib.json"
    },
    {
